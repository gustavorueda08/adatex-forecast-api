# URL of the Strapi backend
STRAPI_URL=http://localhost:1337

# Strapi API token — generate in Strapi admin: Settings > API Tokens
STRAPI_API_TOKEN=26e34b373f123f022335af0499c157b4815a39ad32d2553b1488ee8715016a2af3e4e99c43ea900feeebf8e05b0674a2174e864398ac8629569c0454152942edf4b7632542a92c89117295b8898d81b67ad2e7cdbf1779cf22ef35cee76eb9f5e6012cf33a5cb412f5d48bdd40c8c6f0084a43e4e6a6e0fd0e14804646bdc3e2

# Secret key that the Next.js proxy sends in X-API-Key header
FORECAST_API_KEY=jkjdldjfklsdfjdswueufhefklffej34588ejded

# Forecast horizon in days (default: 90 = 3 months ahead)
FORECAST_HORIZON_DAYS=90

# Assumed supplier lead time in days (used for safety stock calculation)
DEFAULT_LEAD_TIME_DAYS=30

# Target service level for safety stock (0.90 | 0.95 | 0.98 | 0.99)
DEFAULT_SERVICE_LEVEL=0.95

# In-memory cache TTL in seconds (1 hour default — purchase suggestions are expensive to compute)
CACHE_TTL_SECONDS=3600

PORT=8000
